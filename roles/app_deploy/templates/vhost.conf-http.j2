server {
    listen 80;
    server_name {{ app.domain }};

    access_log /var/log/nginx/{{ app.domain }}.access.log;
    error_log /var/log/nginx/{{ app.domain }}.error.log warn;

    keepalive_timeout 300;

    proxy_connect_timeout 300s;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;

    resolver 8.8.8.8 203.119.13.77;

    add_header X-Frame-Options "SAMEORIGIN";

    index index.html index.htm;
    charset utf-8;

    large_client_header_buffers 4 32k;

    include includes/proxy-tunes.conf;

    location / {
        proxy_pass http://127.0.0.1:{{ app.port }};
        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_connect_timeout 300s;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;

        proxy_redirect off;

        proxy_set_header Cache-Control "no-cache, no-store";
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }

    location ~ /\.(htaccess|git|gitignore|gitconfig|svn|bzr|DS_Store|env|htpasswd|ssh|bash_history|bashrc|bash_profile|bash_logout|mysql_history|pgpass|netrc|aws|docker|npmrc|nvmrc|composer|vscode) {
        deny all;
    }
}
